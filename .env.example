# Learning Note generator provider: "openai" (default) or "anthropic".
LLM_PROVIDER=openai
# Required when LLM_PROVIDER=openai.
OPENAI_API_KEY=
# Required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
DATABASE_URL=sqlite:///./database/currentmind.db
RSS_URL=https://indianexpress.com/section/upsc-current-affairs/feed/
LOG_LEVEL=INFO
# Model name for the selected provider, e.g. gpt-4o-mini (OpenAI) or
# claude-haiku-4-5 (Anthropic).
LLM_MODEL=
